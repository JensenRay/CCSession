{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "mainBinaryName" : "CCSession",
  "productName": "CCSession",
  "version": "1.0.1",
  "identifier": "io.toys.ccsession",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CCSession",
        "width": 1024,
        "height": 633
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage",
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
